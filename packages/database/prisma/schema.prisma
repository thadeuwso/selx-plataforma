// SelX 2.0 — schema Prisma (Core v1)
//
// Fonte da modelagem: vault "04 - Banco/Modelo ER/Core.md" (validada em 2026-07-09).
// Convenções: ADR-0002 (RLS), ADR-0004 (nomes português/padrão Sankhya, PKs BIGINT).
// Nomes físicos via @@map/@map — entidades existentes no Sankhya usam o nome real
// (TSIEMP, TSIUSU, TFPFUN, TFPCAR, TSICUS); exclusivas do SelX usam famílias próprias (TSX*, TAU*).
// Políticas RLS vivem no SQL da migration que cria as tabelas (não são geridas pelo Prisma).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Plataforma =====

/// Tenant (grupo econômico). Tabela GLOBAL — raiz do multi-tenant, sem RLS comum.
model Tenant {
  codTen    BigInt   @id @default(autoincrement()) @map("CODTEN")
  nomeTen   String   @map("NOMETEN")
  situacao  String   @default("ATIVO") @map("SITUACAO")
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  dhAlt     DateTime @updatedAt @map("DHALT")
  codUsuAlt BigInt?  @map("CODUSUALT")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  empresas       Empresa[]
  usuarios       Usuario[]
  funcionarios   Funcionario[]
  cargos         Cargo[]
  centros        CentroResultado[]
  papeis         Papel[]
  papelPerms     PapelPermissao[]
  usuarioPapeis  UsuarioPapel[]
  funcHistoricos FuncionarioHistorico[]
  dependentes    Dependente[]
  departamentos  Departamento[]
  projetos       Projeto[]
  contratosServico ContratoServico[]
  logsAuditoria  LogAuditoria[]
  sessoes        Sessao[]
  vagas          Vaga[]
  vagaRequisitos VagaRequisito[]
  vagaPerguntas  VagaPergunta[]
  canais         Canal[]
  vagaCanais     VagaCanal[]
  candidatos     Candidato[]
  candCurriculos CandidatoCurriculo[]
  candidaturas   Candidatura[]
  cdtHistoricos  CandidaturaHistorico[]
  estagioConfigs EstagioConfig[]
  matchResumos   MatchResumo[]
  iaAnalises     IAAnaliseCandidatura[]
  configIa       ConfiguracaoIa?
  culturaPadrao  CulturaPadraoEmpresa?
  emails         EmailFila[]
  entrevistas    Entrevista[]
  entrevistaHorarios EntrevistaHorario[]
  formacoes      FormacaoCandidato[]
  tags           Tag[]
  candidatoTags  CandidatoTag[]
  favoritas      CandidaturaFavorita[]
  filtrosSalvos  FiltroSalvo[]
  propostas      Proposta[]
  planos         PlanoDesenvolvimento[]
  acoesDesenv    AcaoDesenvolvimento[]
  feedbacks      Feedback[]
  ciclosAval     CicloAvaliacao[]
  competenciasCiclo CompetenciaCiclo[]
  avaliacoesDesemp  AvaliacaoDesempenho[]
  notasCompetencia  NotaCompetencia[]
  proximasAcoes     ProximaAcao[]
  respostasCulturais RespostaCultural[]
  documentosModelo DocumentoModelo[]
  assinaturas    Assinatura[]
  kits           KitAdmissional[]
  kitDocumentos  KitAdmissionalDocumento[]
  admissaoProcessos ProcessoAdmissao[]
  admissaoAnexos AdmissaoAnexo[]
  perfisComportamentaisVaga PerfilComportamentalVaga[]
  perfisComportamentaisVagaFatores PerfilComportamentalVagaFator[]
  convitesComportamentais ConviteComportamental[]
  sessoesComportamentais SessaoComportamental[]
  consentimentosComportamentais ConsentimentoComportamental[]
  respostasComportamentais RespostaComportamental[]
  resultadosComportamentais ResultadoComportamental[]
  resultadosComportamentaisFatores ResultadoComportamentalFator[]
  aderenciasComportamentaisVaga AderenciaComportamentalVaga[]
  aderenciasComportamentaisVagaFatores AderenciaComportamentalVagaFator[]
  perfisComportamentaisPadrao PerfilComportamentalPadrao[]
  perfisComportamentaisPadraoFatores PerfilComportamentalPadraoFator[]

  @@map("TSXTEN")
}

// ===== Organização (nomes reais do Sankhya) =====

/// Empresas E filiais na mesma tabela, como no Sankhya. Filial aponta a matriz via codEmpMatriz.
model Empresa {
  codEmp        BigInt   @id @default(autoincrement()) @map("CODEMP")
  codTen        BigInt   @map("CODTEN")
  codEmpMatriz  BigInt?  @map("CODEMPMATRIZ")
  nomeFantasia  String   @map("NOMEFANTASIA")
  razaoSocial   String   @map("RAZAOSOCIAL")
  cgc           String?  @map("CGC")
  codEmpErp     BigInt?  @map("CODEMPERP")
  situacao      String   @default("ATIVA") @map("SITUACAO")
  dhInc         DateTime @default(now()) @map("DHINC")
  codUsuInc     BigInt?  @map("CODUSUINC")
  dhAlt         DateTime @updatedAt @map("DHALT")
  codUsuAlt     BigInt?  @map("CODUSUALT")
  ativo         String   @default("S") @map("ATIVO") @db.Char(1)

  tenant        Tenant    @relation(fields: [codTen], references: [codTen])
  matriz        Empresa?  @relation("MatrizFilial", fields: [codEmpMatriz], references: [codEmp])
  filiais       Empresa[] @relation("MatrizFilial")
  funcionarios  Funcionario[]
  centros       CentroResultado[]
  usuarioPapeis UsuarioPapel[]
  vagas         Vaga[]

  @@index([codTen])
  @@index([codEmpMatriz])
  @@map("TSIEMP")
}

/// Cargos (nome real do Sankhya, confirmado pelo Thadeu).
model Cargo {
  codCar    BigInt   @id @default(autoincrement()) @map("CODCAR")
  codTen    BigInt   @map("CODTEN")
  nomeCar   String   @map("NOMECAR")
  cbo       String?  @map("CBO")
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  dhAlt     DateTime @updatedAt @map("DHALT")
  codUsuAlt BigInt?  @map("CODUSUALT")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  tenant       Tenant        @relation(fields: [codTen], references: [codTen])
  funcionarios Funcionario[]
  vagas        Vaga[]

  @@unique([codTen, nomeCar])
  @@map("TFPCAR")
}

/// Centros de resultado (nome real do Sankhya, confirmado pelo Thadeu). Hierárquico; só analítico recebe lançamento.
model CentroResultado {
  codCencus     BigInt   @id @default(autoincrement()) @map("CODCENCUS")
  codTen        BigInt   @map("CODTEN")
  codEmp        BigInt?  @map("CODEMP")
  descrCencus   String   @map("DESCRCENCUS")
  codCencusPai  BigInt?  @map("CODCENCUSPAI")
  analitico     String   @default("S") @map("ANALITICO") @db.Char(1)
  codCencusErp  BigInt?  @map("CODCENCUSERP")
  dhInc         DateTime @default(now()) @map("DHINC")
  codUsuInc     BigInt?  @map("CODUSUINC")
  dhAlt         DateTime @updatedAt @map("DHALT")
  codUsuAlt     BigInt?  @map("CODUSUALT")
  ativo         String   @default("S") @map("ATIVO") @db.Char(1)

  tenant       Tenant            @relation(fields: [codTen], references: [codTen])
  empresa      Empresa?          @relation(fields: [codEmp], references: [codEmp])
  pai          CentroResultado?  @relation("HierarquiaCencus", fields: [codCencusPai], references: [codCencus])
  filhos       CentroResultado[] @relation("HierarquiaCencus")
  funcionarios Funcionario[]

  @@index([codTen])
  @@map("TSICUS")
}

// ===== Pessoas (nomes reais do Sankhya) =====

/// Funcionários. NUMCAD = matrícula, como no Sankhya. TFPFUNHIS registra os eventos de vida.
model Funcionario {
  codFun       BigInt    @id @default(autoincrement()) @map("CODFUN")
  codTen       BigInt    @map("CODTEN")
  codEmp       BigInt    @map("CODEMP")
  numCad       BigInt    @map("NUMCAD")
  nomeFun      String    @map("NOMEFUN")
  /// E-mail de contato. Sem ele não há como mandar documento para assinatura —
  /// a assinatura eletrônica existia desde a migration 0008 e o link só podia
  /// ser copiado à mão, porque não havia endereço registrado (RN-SX-001).
  email        String?   @map("EMAIL")
  cgc          String?   @map("CGC")
  dtNasc       DateTime? @map("DTNASC") @db.Date
  dtAdm        DateTime  @map("DTADM") @db.Date
  dtDem        DateTime? @map("DTDEM") @db.Date
  codCar       BigInt?   @map("CODCAR")
  codCencus    BigInt?   @map("CODCENCUS")
  codDep       BigInt?   @map("CODDEP")
  codProj      BigInt?   @map("CODPROJ")
  codContrato  BigInt?   @map("CODCONTRATO")
  tipoContrato String    @default("CLT") @map("TIPOCONTRATO")
  vlrSal       Decimal?  @map("VLRSAL") @db.Decimal(15, 2)
  situacao     String    @default("ATIVO") @map("SITUACAO")
  codFunErp    BigInt?   @map("CODFUNERP")
  dhInc        DateTime  @default(now()) @map("DHINC")
  codUsuInc    BigInt?   @map("CODUSUINC")
  dhAlt        DateTime  @updatedAt @map("DHALT")
  codUsuAlt    BigInt?   @map("CODUSUALT")
  ativo        String    @default("S") @map("ATIVO") @db.Char(1)

  tenant          Tenant                 @relation(fields: [codTen], references: [codTen])
  empresa         Empresa                @relation(fields: [codEmp], references: [codEmp])
  cargo           Cargo?                 @relation(fields: [codCar], references: [codCar])
  centroResultado CentroResultado?       @relation(fields: [codCencus], references: [codCencus])
  departamento    Departamento?          @relation(fields: [codDep], references: [codDep])
  projeto         Projeto?               @relation(fields: [codProj], references: [codProj])
  contratoServico ContratoServico?       @relation(fields: [codContrato], references: [codContrato])
  usuario         Usuario?
  historicos      FuncionarioHistorico[]
  planos          PlanoDesenvolvimento[]
  feedbacks       Feedback[]
  avaliacoesDesemp AvaliacaoDesempenho[]
  proximasAcoes   ProximaAcao[]
  dependentes     Dependente[]
  candidaturasOrigem Candidatura[]
  assinaturas        Assinatura[]

  @@unique([codTen, codEmp, numCad])
  @@index([codTen])
  @@index([codEmp])
  @@map("TFPFUN")
}

/// Histórico de mudanças do funcionário — fonte dos "eventos de vida" consumidos pelos módulos.
model FuncionarioHistorico {
  codFunHis BigInt   @id @default(autoincrement()) @map("CODFUNHIS")
  codTen    BigInt   @map("CODTEN")
  codFun    BigInt   @map("CODFUN")
  tipoMud   String   @map("TIPOMUD")
  valorAnt  String?  @map("VALORANT")
  valorNovo String?  @map("VALORNOVO")
  dtMud     DateTime @map("DTMUD") @db.Date
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")

  tenant      Tenant      @relation(fields: [codTen], references: [codTen])
  funcionario Funcionario @relation(fields: [codFun], references: [codFun])

  @@index([codTen, codFun])
  @@map("TFPFUNHIS")
}

/// Dependentes do funcionário (nome real do Sankhya, confirmado pelo Thadeu em 2026-07-10).
model Dependente {
  codDpd BigInt    @id @default(autoincrement()) @map("CODDPD")
  codTen    BigInt    @map("CODTEN")
  codFun    BigInt    @map("CODFUN")
  nomeDpd String   @map("NOMEDPD")
  tipoDpd String   @map("TIPODPD")
  dtNasc    DateTime? @map("DTNASC") @db.Date
  cgc       String?   @map("CGC")
  dhInc     DateTime  @default(now()) @map("DHINC")
  codUsuInc BigInt?   @map("CODUSUINC")
  dhAlt     DateTime  @updatedAt @map("DHALT")
  codUsuAlt BigInt?   @map("CODUSUALT")
  ativo     String    @default("S") @map("ATIVO") @db.Char(1)

  tenant      Tenant      @relation(fields: [codTen], references: [codTen])
  funcionario Funcionario @relation(fields: [codFun], references: [codFun])

  @@index([codTen, codFun])
  @@map("TFPDPD")
}

// ===== Acesso (TSIUSU espelha Sankhya; RBAC é exclusivo do SelX — família TSX) =====

model Usuario {
  codUsu      BigInt    @id @default(autoincrement()) @map("CODUSU")
  codTen      BigInt    @map("CODTEN")
  nomeUsu     String    @map("NOMEUSU")
  email       String    @map("EMAIL")
  senha       String    @map("SENHA")
  codFun      BigInt?   @unique @map("CODFUN")
  situacao    String    @default("ATIVO") @map("SITUACAO")
  dhUltAcesso DateTime? @map("DHULTACESSO")
  dhInc       DateTime  @default(now()) @map("DHINC")
  codUsuInc   BigInt?   @map("CODUSUINC")
  dhAlt       DateTime  @updatedAt @map("DHALT")
  codUsuAlt   BigInt?   @map("CODUSUALT")
  ativo       String    @default("S") @map("ATIVO") @db.Char(1)

  tenant      Tenant         @relation(fields: [codTen], references: [codTen])
  funcionario Funcionario?   @relation(fields: [codFun], references: [codFun])
  papeis      UsuarioPapel[]
  sessoes     Sessao[]
  vagasResp   Vaga[]         @relation("VagaResponsavel")
  entrevistas Entrevista[]   @relation("EntrevistaEntrevistador")
  pdisResp    PlanoDesenvolvimento[] @relation("PdiResponsavel")
  feedbacksAutor Feedback[]          @relation("FeedbackAutor")
  avaliacoesFeitas AvaliacaoDesempenho[] @relation("AvaliadorDesempenho")
  proximasAcoesResp ProximaAcao[]       @relation("ProximaAcaoResp")
  favoritas   CandidaturaFavorita[]
  filtrosSalvos FiltroSalvo[]

  @@unique([codTen, email])
  @@map("TSIUSU")
}

model Papel {
  codPap    BigInt   @id @default(autoincrement()) @map("CODPAP")
  codTen    BigInt   @map("CODTEN")
  nomePap   String   @map("NOMEPAP")
  descrPap  String?  @map("DESCRPAP")
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  dhAlt     DateTime @updatedAt @map("DHALT")
  codUsuAlt BigInt?  @map("CODUSUALT")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  tenant      Tenant           @relation(fields: [codTen], references: [codTen])
  permissoes  PapelPermissao[]
  atribuicoes UsuarioPapel[]

  @@unique([codTen, nomePap])
  @@map("TSXPAP")
}

/// Catálogo de permissões. Tabela GLOBAL (sem tenant) — semeada pela plataforma.
model Permissao {
  codPerm   BigInt   @id @default(autoincrement()) @map("CODPERM")
  chavePerm String   @unique @map("CHAVEPERM")
  descrPerm String   @map("DESCRPERM")
  dhInc     DateTime @default(now()) @map("DHINC")

  papeis PapelPermissao[]

  @@map("TSXPERM")
}

model PapelPermissao {
  codPapPerm BigInt   @id @default(autoincrement()) @map("CODPAPPERM")
  codTen     BigInt   @map("CODTEN")
  codPap     BigInt   @map("CODPAP")
  codPerm    BigInt   @map("CODPERM")
  dhInc      DateTime @default(now()) @map("DHINC")
  codUsuInc  BigInt?  @map("CODUSUINC")

  tenant    Tenant    @relation(fields: [codTen], references: [codTen])
  papel     Papel     @relation(fields: [codPap], references: [codPap])
  permissao Permissao @relation(fields: [codPerm], references: [codPerm])

  @@unique([codPap, codPerm])
  @@index([codTen])
  @@map("TSXPAPPERM")
}

/// Usuário × papel com escopo opcional por empresa (ABAC). codEmp nulo = tenant inteiro.
model UsuarioPapel {
  codUsuPap BigInt   @id @default(autoincrement()) @map("CODUSUPAP")
  codTen    BigInt   @map("CODTEN")
  codUsu    BigInt   @map("CODUSU")
  codPap    BigInt   @map("CODPAP")
  codEmp    BigInt?  @map("CODEMP")
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  tenant  Tenant   @relation(fields: [codTen], references: [codTen])
  usuario Usuario  @relation(fields: [codUsu], references: [codUsu])
  papel   Papel    @relation(fields: [codPap], references: [codPap])
  empresa Empresa? @relation(fields: [codEmp], references: [codEmp])

  @@index([codTen, codUsu])
  @@map("TSXUSUPAP")
}

// ===== Auditoria universal da plataforma =====

model LogAuditoria {
  codAud     BigInt   @id @default(autoincrement()) @map("CODAUD")
  codTen     BigInt   @map("CODTEN")
  nomeTab    String   @map("NOMETAB")
  codReg     BigInt   @map("CODREG")
  operacao   String   @map("OPERACAO")
  dadosAnt   Json?    @map("DADOSANT")
  dadosNovos Json?    @map("DADOSNOVOS")
  motivo     String?  @map("MOTIVO")
  origem     String   @map("ORIGEM")
  dhAlt      DateTime @default(now()) @map("DHALT")
  codUsuAlt  BigInt?  @map("CODUSUALT")

  tenant Tenant @relation(fields: [codTen], references: [codTen])

  @@index([codTen, nomeTab, codReg])
  @@map("TAULOG")
}

/// Sessões de autenticação — refresh tokens com revogação (logout/rotação).
model Sessao {
  codSes    BigInt    @id @default(autoincrement()) @map("CODSES")
  codTen    BigInt    @map("CODTEN")
  codUsu    BigInt    @map("CODUSU")
  tokenHash String    @unique @map("TOKENHASH")
  dhExp     DateTime  @map("DHEXP")
  dhRevog   DateTime? @map("DHREVOG")
  agente    String?   @map("AGENTE")
  dhInc     DateTime  @default(now()) @map("DHINC")

  tenant  Tenant  @relation(fields: [codTen], references: [codTen])
  usuario Usuario @relation(fields: [codUsu], references: [codUsu])

  @@index([codTen, codUsu])
  @@map("TSXSES")
}

/// Departamentos (nome real do Sankhya). Hierárquico; ANALITICO = recebe lotação.
model Departamento {
  codDep    BigInt   @id @default(autoincrement()) @map("CODDEP")
  codTen    BigInt   @map("CODTEN")
  descrDep  String   @map("DESCRDEP")
  codDepPai BigInt?  @map("CODDEPPAI")
  grau      Int      @default(1) @map("GRAU")
  analitico String   @default("S") @map("ANALITICO") @db.Char(1)
  codCencus BigInt?  @map("CODCENCUS")
  codDepErp BigInt?  @map("CODDEPERP")
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  dhAlt     DateTime @updatedAt @map("DHALT")
  codUsuAlt BigInt?  @map("CODUSUALT")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  tenant       Tenant         @relation(fields: [codTen], references: [codTen])
  pai          Departamento?  @relation("HierarquiaDep", fields: [codDepPai], references: [codDep])
  filhos       Departamento[] @relation("HierarquiaDep")
  funcionarios Funcionario[]
  vagas        Vaga[]

  @@index([codTen])
  @@map("TFPDEP")
}

/// Projetos (espelho do print Sankhya 2026-07-10: hierárquico, identificação+abreviatura, vigência, orçamento).
model Projeto {
  codProj   BigInt   @id @default(autoincrement()) @map("CODPROJ")
  codTen    BigInt   @map("CODTEN")
  identificacao String @map("IDENTIFICACAO")
  abreviatura   String @map("ABREVIATURA")
  codProjPai BigInt?  @map("CODPROJPAI")
  grau      Int      @default(1) @map("GRAU")
  analitico String   @default("S") @map("ANALITICO") @db.Char(1)
  dtInicio  DateTime? @map("DTINICIO") @db.Date
  dtTermino DateTime? @map("DTTERMINO") @db.Date
  vlrOrcado Decimal? @map("VLRORCADO") @db.Decimal(15, 2)
  concluido String   @default("N") @map("CONCLUIDO") @db.Char(1)
  codUsuResp BigInt? @map("CODUSURESP")
  codEmp    BigInt?  @map("CODEMP")
  codProjErp BigInt? @map("CODPROJERP")
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  dhAlt     DateTime @updatedAt @map("DHALT")
  codUsuAlt BigInt?  @map("CODUSUALT")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  tenant       Tenant        @relation(fields: [codTen], references: [codTen])
  pai          Projeto?      @relation("HierarquiaProj", fields: [codProjPai], references: [codProj])
  filhos       Projeto[]     @relation("HierarquiaProj")
  contratos    ContratoServico[]
  funcionarios Funcionario[]

  @@index([codTen])
  @@map("TCSPRJ")
}

/// Contratos de serviço (espelho do print Sankhya 2026-07-10: vinculado a projeto, tipo, parcelas, faturamento).
model ContratoServico {
  codContrato BigInt   @id @default(autoincrement()) @map("CODCONTRATO")
  codTen      BigInt   @map("CODTEN")
  numContrato String?  @map("NUMCONTRATO")
  descrContrato String @map("DESCRCONTRATO")
  codProj     BigInt?  @map("CODPROJ")
  dtTermino   DateTime? @map("DTTERMINO") @db.Date
  tipo        String   @default("M") @map("TIPO") @db.Char(1)
  vlrHora     Decimal? @map("VLRHORA") @db.Decimal(15, 2)
  parcelaQtd  Int?     @map("PARCELAQTD")
  dtRefProxFat DateTime? @map("DTREFPROXFAT") @db.Date
  codEmp      BigInt?  @map("CODEMP")
  codContratoErp BigInt? @map("CODCONTRATOERP")
  dhInc       DateTime @default(now()) @map("DHINC")
  codUsuInc   BigInt?  @map("CODUSUINC")
  dhAlt       DateTime @updatedAt @map("DHALT")
  codUsuAlt   BigInt?  @map("CODUSUALT")
  ativo       String   @default("S") @map("ATIVO") @db.Char(1)

  tenant       Tenant        @relation(fields: [codTen], references: [codTen])
  projeto      Projeto?      @relation(fields: [codProj], references: [codProj])
  funcionarios Funcionario[]

  @@index([codTen])
  @@map("TCSCON")
}

// ===== Recrutamento (família TRE — modelo aprovado pelo Thadeu em 2026-07-11) =====

/// Vaga com ciclo de aprovação (herdado do 1.0 em produção).
model Vaga {
  codVag        BigInt    @id @default(autoincrement()) @map("CODVAG")
  codTen        BigInt    @map("CODTEN")
  codEmp        BigInt    @map("CODEMP")
  titulo        String    @map("TITULO")
  descrVag      String?   @map("DESCRVAG")
  local         String?   @map("LOCAL")
  senioridade   String?   @map("SENIORIDADE")
  status        String    @default("RASCUNHO") @map("STATUS")
  urgente       String    @default("N") @map("URGENTE") @db.Char(1)
  dhPub         DateTime? @map("DHPUB")
  codUsuAprov   BigInt?   @map("CODUSUAPROV")
  dhAprov       DateTime? @map("DHAPROV")
  obsAprov      String?   @map("OBSAPROV")
  motivoCancel  String?   @map("MOTIVOCANCEL")
  codCandContratado BigInt? @map("CODCANDCONTRATADO")
  vlrSalMin     Decimal?  @map("VLRSALMIN") @db.Decimal(15, 2)
  vlrSalMax     Decimal?  @map("VLRSALMAX") @db.Decimal(15, 2)
  salaVista     String    @default("N") @map("SALAVISTA") @db.Char(1)
  modeloTrab    String?   @map("MODELOTRAB")
  tipoContrato  String?   @map("TIPOCONTRATO")
  codDep        BigInt?   @map("CODDEP")
  codCar        BigInt?   @map("CODCAR")
  /// Recrutador responsável pela vaga (RN-REC-012) — FK p/ TSIUSU, nulo = sem dono definido.
  codUsuResp    BigInt?   @map("CODUSURESP")
  /// Perfil cultural ideal da vaga p/ match determinístico (RN-REC-006) — {autonomy,pace,collaboration,structure,dataDriven,directCommunication}, escala 1-5.
  perfilCulturalIdealJson  Json?     @map("PERFILCULTURALIDEALJSON")
  dhInc         DateTime  @default(now()) @map("DHINC")
  codUsuInc     BigInt?   @map("CODUSUINC")
  dhAlt         DateTime  @updatedAt @map("DHALT")
  codUsuAlt     BigInt?   @map("CODUSUALT")
  ativo         String    @default("S") @map("ATIVO") @db.Char(1)

  tenant       Tenant        @relation(fields: [codTen], references: [codTen])
  empresa      Empresa       @relation(fields: [codEmp], references: [codEmp])
  departamento Departamento? @relation(fields: [codDep], references: [codDep])
  cargo        Cargo?        @relation(fields: [codCar], references: [codCar])
  responsavel  Usuario?      @relation("VagaResponsavel", fields: [codUsuResp], references: [codUsu])
  requisitos   VagaRequisito[]
  entrevistaHorarios EntrevistaHorario[]
  perguntas    VagaPergunta[]
  canais       VagaCanal[]
  candidaturas Candidatura[]
  perfisComportamentais PerfilComportamentalVaga[]

  @@index([codTen, status])
  @@map("TREVAG")
}

model VagaRequisito {
  codVagReq BigInt   @id @default(autoincrement()) @map("CODVAGREQ")
  codTen    BigInt   @map("CODTEN")
  codVag    BigInt   @map("CODVAG")
  descrReq  String   @map("DESCRREQ")
  tipoReq   String   @default("OBRIGATORIO") @map("TIPOREQ")
  knockout  String   @default("N") @map("KNOCKOUT") @db.Char(1)
  ordem     Int      @default(1) @map("ORDEM")
  /// Peso 0-10 no match determinístico (RN-REC-006).
  peso              Int      @default(5) @map("PESO")
  nivelEsperado     Int?     @map("NIVELESPERADO")
  tempoEspMeses     Int?     @map("TEMPOESPMESES")
  evidenciaExigida  String   @default("N") @map("EVIDENCIAEXIGIDA") @db.Char(1)
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)
  dhInc     DateTime @default(now()) @map("DHINC")

  tenant Tenant @relation(fields: [codTen], references: [codTen])
  vaga   Vaga   @relation(fields: [codVag], references: [codVag])

  @@index([codTen, codVag])
  @@map("TREVAGREQ")
}

model VagaPergunta {
  codVagPer   BigInt   @id @default(autoincrement()) @map("CODVAGPER")
  codTen      BigInt   @map("CODTEN")
  codVag      BigInt   @map("CODVAG")
  pergunta    String   @map("PERGUNTA")
  tipoResp    String   @default("SIM_NAO") @map("TIPORESP")
  obrigatoria String   @default("S") @map("OBRIGATORIA") @db.Char(1)
  respElimina String?  @map("RESPELIMINA")
  ordem       Int      @default(1) @map("ORDEM")
  ativo       String   @default("S") @map("ATIVO") @db.Char(1)
  dhInc       DateTime @default(now()) @map("DHINC")

  tenant Tenant @relation(fields: [codTen], references: [codTen])
  vaga   Vaga   @relation(fields: [codVag], references: [codVag])

  @@index([codTen, codVag])
  @@map("TREVAGPER")
}

/// Canal de captação (vagas.com, Catho, Empregare, indicação, importação, manual...).
model Canal {
  codCanal    BigInt   @id @default(autoincrement()) @map("CODCANAL")
  codTen      BigInt   @map("CODTEN")
  nomeCanal   String   @map("NOMECANAL")
  tipoCanal   String   @default("manual") @map("TIPOCANAL")
  vlrCustoMes Decimal? @map("VLRCUSTOMES") @db.Decimal(15, 2)
  dhInc       DateTime @default(now()) @map("DHINC")
  codUsuInc   BigInt?  @map("CODUSUINC")
  dhAlt       DateTime @updatedAt @map("DHALT")
  codUsuAlt   BigInt?  @map("CODUSUALT")
  ativo       String   @default("S") @map("ATIVO") @db.Char(1)

  tenant       Tenant        @relation(fields: [codTen], references: [codTen])
  publicacoes  VagaCanal[]
  candidaturas Candidatura[]

  @@unique([codTen, nomeCanal])
  @@map("TRECANAL")
}

model VagaCanal {
  codVagCanal BigInt    @id @default(autoincrement()) @map("CODVAGCANAL")
  codTen      BigInt    @map("CODTEN")
  codVag      BigInt    @map("CODVAG")
  codCanal    BigInt    @map("CODCANAL")
  idExterno   String?   @map("IDEXTERNO")
  urlExterna  String?   @map("URLEXTERNA")
  dhPub       DateTime? @map("DHPUB")
  status      String    @default("PUBLICADA") @map("STATUS")
  dhInc       DateTime  @default(now()) @map("DHINC")
  codUsuInc   BigInt?   @map("CODUSUINC")

  tenant Tenant @relation(fields: [codTen], references: [codTen])
  vaga   Vaga   @relation(fields: [codVag], references: [codVag])
  canal  Canal  @relation(fields: [codCanal], references: [codCanal])

  @@index([codTen, codVag])
  @@map("TREVAGCANAL")
}

/// Candidato — banco de talentos por TENANT, dedup por e-mail/CPF (RN-REC-009).
model Candidato {
  codCand   BigInt   @id @default(autoincrement()) @map("CODCAND")
  codTen    BigInt   @map("CODTEN")
  nomeCand  String   @map("NOMECAND")
  email     String   @map("EMAIL")
  fone      String?  @map("FONE")
  cgc       String?  @map("CGC")
  linkedin  String?  @map("LINKEDIN")
  cidade    String?  @map("CIDADE")
  cargoAtual String? @map("CARGOATUAL")
  codUsu    BigInt?  @map("CODUSU")
  /// Perfil cultural p/ match determinístico (RN-REC-006) — mesmo formato de Vaga.perfilCulturalIdealJson, reaproveitado entre candidaturas.
  perfilCulturalJson  Json?  @map("PERFILCULTURALJSON")
  /// De onde veio o perfil: "CANDIDATO" (respondeu o questionário) ou
  /// "RECRUTADOR" (digitado à mão no cadastro). Nasceu porque as duas origens
  /// eram indistinguíveis na tela — uma é medida, a outra é palpite, e quem lê
  /// o fit cultural precisa saber qual está vendo (RN-REC-014).
  perfilCulturalOrigem String?   @map("PERFILCULTURALORIGEM")
  perfilCulturalDh     DateTime? @map("PERFILCULTURALDH")

  // ===== Campos estruturados (RN-REC-016) =====
  // Eram texto solto no currículo — o recrutador lia um a um e não conseguia
  // filtrar. Tipados, entram em busca, ordenação e comparação.

  /// Pretensão salarial mensal. Sem moeda: a plataforma é BRL até existir
  /// operação fora do Brasil, e uma coluna de moeda sempre "BRL" só mente.
  pretensaoSalarial    Decimal?  @map("PRETENSAOSALARIAL") @db.Decimal(15, 2)
  /// "S" quando o candidato aceita negociar. Muda completamente a leitura de
  /// uma pretensão acima da faixa da vaga.
  pretensaoNegociavel  String?   @map("PRETENSAONEGOCIAVEL") @db.Char(1)
  /// IMEDIATA | AVISO_PREVIO | A_PARTIR_DE
  dispTipo             String?   @map("DISPTIPO")
  /// Dias de aviso prévio a cumprir — só faz sentido com dispTipo=AVISO_PREVIO.
  dispAvisoDias        Int?      @map("DISPAVISODIAS")
  /// Data a partir da qual pode começar — só com dispTipo=A_PARTIR_DE.
  dispData             DateTime? @map("DISPDATA") @db.Date

  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  dhAlt     DateTime @updatedAt @map("DHALT")
  codUsuAlt BigInt?  @map("CODUSUALT")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  tenant       Tenant               @relation(fields: [codTen], references: [codTen])
  curriculos   CandidatoCurriculo[]
  respostasCulturais RespostaCultural[]
  formacoes    FormacaoCandidato[]
  tags         CandidatoTag[]
  candidaturas Candidatura[]

  @@unique([codTen, email])
  @@index([codTen, cgc])
  @@map("TRECAND")
}

model CandidatoCurriculo {
  codCandCv     BigInt   @id @default(autoincrement()) @map("CODCANDCV")
  codTen        BigInt   @map("CODTEN")
  codCand       BigInt   @map("CODCAND")
  arquivo       String   @map("ARQUIVO")
  textoExtraido String?  @map("TEXTOEXTRAIDO")
  dhInc         DateTime @default(now()) @map("DHINC")

  tenant    Tenant    @relation(fields: [codTen], references: [codTen])
  candidato Candidato @relation(fields: [codCand], references: [codCand])

  @@index([codTen, codCand])
  @@map("TRECANDCV")
}

/// Candidatura — única por vaga+candidato; idempotência por (CODCANAL, IDEXTERNO).
model Candidatura {
  codCdt        BigInt   @id @default(autoincrement()) @map("CODCDT")
  codTen        BigInt   @map("CODTEN")
  codVag        BigInt   @map("CODVAG")
  codCand       BigInt   @map("CODCAND")
  estagio       String   @default("applied") @map("ESTAGIO")
  /// Token opaco do portal de acompanhamento do candidato (ADR-0004 §5).
  /// Gerado sob demanda pelo RH — candidatura antiga fica sem até alguém pedir o link.
  tokenPub      String?  @unique @map("TOKENPUB")
  codCanal      BigInt   @map("CODCANAL")
  idExterno     String?  @map("IDEXTERNO")
  codFun        BigInt?  @map("CODFUN") // RN-REC-007: preenchido ao confirmar admissao no Core
  respostasJson Json?    @map("RESPOSTASJSON")
  knockoutJson  Json?    @map("KNOCKOUTJSON")
  /// Autoavaliação por requisito p/ match determinístico (RN-REC-006) — mapa codVagReq -> {nivel,tempoMeses,evidenciaTexto}.
  autoavaliacaoJson  Json?  @map("AUTOAVALIACAOJSON")
  dhInc         DateTime @default(now()) @map("DHINC")
  codUsuInc     BigInt?  @map("CODUSUINC")
  dhAlt         DateTime @updatedAt @map("DHALT")
  codUsuAlt     BigInt?  @map("CODUSUALT")
  ativo         String   @default("S") @map("ATIVO") @db.Char(1)

  tenant    Tenant                 @relation(fields: [codTen], references: [codTen])
  vaga      Vaga                   @relation(fields: [codVag], references: [codVag])
  candidato Candidato              @relation(fields: [codCand], references: [codCand])
  canal     Canal                  @relation(fields: [codCanal], references: [codCanal])
  funcionario Funcionario?         @relation(fields: [codFun], references: [codFun])
  timeline  CandidaturaHistorico[]
  match     MatchResumo?
  iaAnalises IAAnaliseCandidatura[]
  entrevistas Entrevista[]
  favoritas  CandidaturaFavorita[]
  propostas  Proposta[]
  processoAdmissao ProcessoAdmissao?
  convitesComportamentais ConviteComportamental[]

  @@unique([codVag, codCand])
  @@index([codTen, codVag, estagio])
  @@map("TRECDT")
}

/// Timeline/event log da candidatura — alimenta candidato, auditoria e ML.
model CandidaturaHistorico {
  codCdtHis     BigInt   @id @default(autoincrement()) @map("CODCDTHIS")
  codTen        BigInt   @map("CODTEN")
  codCdt        BigInt   @map("CODCDT")
  tipoEvento    String   @map("TIPOEVENTO")
  estagioAnt    String?  @map("ESTAGIOANT")
  estagioNovo   String?  @map("ESTAGIONOVO")
  rotuloPub     String?  @map("ROTULOPUB")
  notaInterna   String?  @map("NOTAINTERNA")
  tipoAtor      String   @default("usuario") @map("TIPOATOR")
  metadadosJson Json?    @map("METADADOSJSON")
  dhInc         DateTime @default(now()) @map("DHINC")
  codUsuInc     BigInt?  @map("CODUSUINC")

  tenant      Tenant      @relation(fields: [codTen], references: [codTen])
  candidatura Candidatura @relation(fields: [codCdt], references: [codCdt])

  @@index([codTen, codCdt])
  @@map("TRECDTHIS")
}

/// Configuração de estágio do pipeline por tenant/empresa (rótulos públicos, ordem, visibilidade).
model EstagioConfig {
  codEtpCfg BigInt   @id @default(autoincrement()) @map("CODETPCFG")
  codTen    BigInt   @map("CODTEN")
  codEmp    BigInt?  @map("CODEMP")
  estagio   String   @map("ESTAGIO")
  ordem     Int      @map("ORDEM")
  rotuloPub String   @map("ROTULOPUB")
  descrPub  String?  @map("DESCRPUB")
  visivel   String   @default("S") @map("VISIVEL") @db.Char(1)
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  dhAlt     DateTime @updatedAt @map("DHALT")
  codUsuAlt BigInt?  @map("CODUSUALT")

  tenant Tenant @relation(fields: [codTen], references: [codTen])

  @@unique([codTen, codEmp, estagio])
  @@map("TREETPCFG")
}

/// Cultura padrão da empresa (RN-REC-014) — herdada pela vaga que não define a
/// própria, mesmo desenho do Padrão Comportamental (`TGPPERPAD`).
///
/// JSON e não colunas tipadas, contrariando a preferência geral do projeto, por
/// coerência: o lado da vaga (`TREVAG.PERFILCULTURALIDEALJSON`) já é JSON e o
/// motor de match lê os dois com a mesma função. Duas formas para o mesmo dado
/// custaria mais do que ganha.
model CulturaPadraoEmpresa {
  codCulEmp  BigInt   @id @default(autoincrement()) @map("CODCULEMP")
  codTen     BigInt   @unique @map("CODTEN")
  perfilJson Json     @map("PERFILJSON")
  dhInc      DateTime @default(now()) @map("DHINC")
  codUsuInc  BigInt?  @map("CODUSUINC")
  dhAlt      DateTime @updatedAt @map("DHALT")
  codUsuAlt  BigInt?  @map("CODUSUALT")

  tenant Tenant @relation(fields: [codTen], references: [codTen])

  @@map("TRECULEMP")
}

/// Banco de afirmações do questionário cultural (RN-REC-014).
///
/// Global como o banco comportamental (`TGPPER`): é metodologia da plataforma,
/// não conteúdo do tenant. Cada dimensão tem afirmações diretas e reversas —
/// a reversa existe para pegar quem responde tudo no mesmo extremo, mesma
/// razão do questionário comportamental.
model PerguntaCultural {
  codCulPer BigInt   @id @default(autoincrement()) @map("CODCULPER")
  dimensao  String   @map("DIMENSAO")
  texto     String   @map("TEXTO")
  /// "S" inverte o valor na apuração (`6 - valor`).
  reversa   String   @default("N") @map("REVERSA") @db.Char(1)
  ordem     Int      @map("ORDEM")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)
  dhInc     DateTime @default(now()) @map("DHINC")

  respostas RespostaCultural[]

  @@map("TRECULPER")
}

/// Resposta do candidato ao questionário cultural.
///
/// Guardar a resposta crua, e não só o perfil apurado, é o que permite
/// recalcular quando a fórmula mudar e mostrar ao recrutador em que o número se
/// apoia — mesma decisão já tomada no comportamental (`TGPRESP`).
model RespostaCultural {
  codCulResp BigInt   @id @default(autoincrement()) @map("CODCULRESP")
  codTen     BigInt   @map("CODTEN")
  codCand    BigInt   @map("CODCAND")
  codCulPer  BigInt   @map("CODCULPER")
  valor      Int      @map("VALOR")
  dhInc      DateTime @default(now()) @map("DHINC")

  tenant    Tenant           @relation(fields: [codTen], references: [codTen])
  candidato Candidato        @relation(fields: [codCand], references: [codCand])
  pergunta  PerguntaCultural @relation(fields: [codCulPer], references: [codCulPer])

  @@unique([codCand, codCulPer])
  @@index([codTen, codCand])
  @@map("TRECULRESP")
}

// ===== Gestão de Pessoas — Fase 2: Desempenho e Desenvolvimento (TGP) =====
// PDI, treinamentos, feedbacks e avaliação de desempenho do funcionário, da
// entrada em diante. NUNCA cálculo de folha (RN-GP-020, decisão do Thadeu) —
// folha é o módulo TAF, separado.

/// Plano de Desenvolvimento Individual (RN-GP-020).
///
/// Nasce colado à admissão: o funcionário admitido já entra com um plano, em
/// vez de esperar meses por uma primeira conversa de desenvolvimento. Aponta
/// para `TFPFUN` (Core) sem duplicar dado de cadastro.
model PlanoDesenvolvimento {
  codPdi     BigInt    @id @default(autoincrement()) @map("CODPDI")
  codTen     BigInt    @map("CODTEN")
  codFun     BigInt    @map("CODFUN")
  titulo     String    @map("TITULO")
  objetivo   String?   @map("OBJETIVO") @db.Text
  /// Quem conduz o plano — FK p/ TSIUSU, o gestor/RH responsável.
  codUsuResp BigInt?   @map("CODUSURESP")
  dtInicio   DateTime  @default(now()) @map("DTINICIO") @db.Date
  dtRevisao  DateTime? @map("DTREVISAO") @db.Date
  /// RASCUNHO | ATIVO | CONCLUIDO | CANCELADO
  status     String    @default("ATIVO") @map("STATUS")
  dhInc      DateTime  @default(now()) @map("DHINC")
  codUsuInc  BigInt?   @map("CODUSUINC")
  dhAlt      DateTime  @updatedAt @map("DHALT")
  codUsuAlt  BigInt?   @map("CODUSUALT")

  tenant      Tenant       @relation(fields: [codTen], references: [codTen])
  funcionario Funcionario  @relation(fields: [codFun], references: [codFun])
  responsavel Usuario?     @relation("PdiResponsavel", fields: [codUsuResp], references: [codUsu])
  acoes       AcaoDesenvolvimento[]
  feedbacks   Feedback[]

  @@index([codTen, codFun])
  @@map("TGPPDI")
}

/// Ação de desenvolvimento dentro do PDI (RN-GP-020).
///
/// A unidade concreta do plano: um treinamento, uma leitura, um projeto, uma
/// mentoria. O plano é a intenção; as ações são o que de fato se faz e se
/// acompanha.
model AcaoDesenvolvimento {
  codAcao      BigInt    @id @default(autoincrement()) @map("CODACAO")
  codTen       BigInt    @map("CODTEN")
  codPdi       BigInt    @map("CODPDI")
  descricao    String    @map("DESCRICAO")
  /// TREINAMENTO | LEITURA | PROJETO | MENTORIA | CERTIFICACAO | OUTRO
  tipo         String    @default("TREINAMENTO") @map("TIPO")
  competencia  String?   @map("COMPETENCIA")
  prazo        DateTime? @map("PRAZO") @db.Date
  /// PENDENTE | EM_ANDAMENTO | CONCLUIDA | CANCELADA
  status       String    @default("PENDENTE") @map("STATUS")
  /// 0 a 100 — andamento auto-informado, para acompanhar sem binário.
  progresso    Int       @default(0) @map("PROGRESSO")
  dhConclusao  DateTime? @map("DHCONCLUSAO")
  ordem        Int       @default(0) @map("ORDEM")
  dhInc        DateTime  @default(now()) @map("DHINC")
  codUsuInc    BigInt?   @map("CODUSUINC")
  dhAlt        DateTime  @updatedAt @map("DHALT")

  tenant Tenant               @relation(fields: [codTen], references: [codTen])
  plano  PlanoDesenvolvimento @relation(fields: [codPdi], references: [codPdi])

  @@index([codTen, codPdi])
  @@map("TGPACAO")
}

/// Feedback registrado ao funcionário (RN-GP-021).
///
/// Retorno contínuo, não o evento anual de avaliação. Pode nascer solto (um
/// elogio pontual) ou preso a um plano de desenvolvimento (retorno sobre uma
/// ação) — `codPdi` opcional cobre os dois sem duas tabelas.
///
/// Registrado por um usuário (`codUsuAutor`, o gestor/par) sobre um funcionário.
/// Não se apaga nem se edita depois de dado: feedback é evento histórico, e
/// reescrevê-lo apagaria o que a pessoa de fato recebeu. Corrigir é dar outro.
model Feedback {
  codFeed     BigInt   @id @default(autoincrement()) @map("CODFEED")
  codTen      BigInt   @map("CODTEN")
  codFun      BigInt   @map("CODFUN")
  /// Opcional: vincula o feedback a um plano de desenvolvimento.
  codPdi      BigInt?  @map("CODPDI")
  /// POSITIVO | CONSTRUTIVO | NEUTRO — o tom, não uma nota.
  tipo        String   @default("NEUTRO") @map("TIPO")
  /// RECONHECIMENTO | MELHORIA | ACOMPANHAMENTO | OUTRO — o contexto.
  contexto    String   @default("ACOMPANHAMENTO") @map("CONTEXTO")
  mensagem    String   @map("MENSAGEM") @db.Text
  /// Quem deu o feedback — FK p/ TSIUSU.
  codUsuAutor BigInt   @map("CODUSUAUTOR")
  /// "S" quando o funcionário deu ciência (via portal, no futuro). Nulo = ainda
  /// não visto. Feedback dado no escuro não é feedback.
  cienteFun   String?  @map("CIENTEFUN") @db.Char(1)
  dhCiente    DateTime? @map("DHCIENTE")
  dhInc       DateTime @default(now()) @map("DHINC")

  tenant      Tenant                @relation(fields: [codTen], references: [codTen])
  funcionario Funcionario           @relation(fields: [codFun], references: [codFun])
  plano       PlanoDesenvolvimento? @relation(fields: [codPdi], references: [codPdi])
  autor       Usuario               @relation("FeedbackAutor", fields: [codUsuAutor], references: [codUsu])

  @@index([codTen, codFun])
  @@map("TGPFEED")
}

/// Ciclo de avaliação de desempenho (RN-GP-022).
///
/// A campanha: "Avaliação Semestral 2026/2", com período e um conjunto de
/// competências a avaliar. Uma avaliação de desempenho sempre vive dentro de um
/// ciclo — nota solta, sem período nem critério, não diz nada.
///
/// Distinto do feedback (RN-GP-021): feedback é contínuo e pontual; o ciclo é o
/// momento estruturado, periódico, com competências e nota.
model CicloAvaliacao {
  codCiclo   BigInt    @id @default(autoincrement()) @map("CODCICLO")
  codTen     BigInt    @map("CODTEN")
  nome       String    @map("NOME")
  descricao  String?   @map("DESCRICAO") @db.Text
  dtInicio   DateTime  @map("DTINICIO") @db.Date
  dtFim      DateTime  @map("DTFIM") @db.Date
  /// RASCUNHO | ABERTO | ENCERRADO. Enquanto RASCUNHO se ajustam competências;
  /// ABERTO os avaliadores preenchem; ENCERRADO congela.
  status     String    @default("RASCUNHO") @map("STATUS")
  dhInc      DateTime  @default(now()) @map("DHINC")
  codUsuInc  BigInt?   @map("CODUSUINC")
  dhAlt      DateTime  @updatedAt @map("DHALT")

  tenant       Tenant                @relation(fields: [codTen], references: [codTen])
  competencias CompetenciaCiclo[]
  avaliacoes   AvaliacaoDesempenho[]

  @@index([codTen, status])
  @@map("TGPCICLO")
}

/// Competência avaliada em um ciclo (RN-GP-022).
///
/// O que se avalia — "Colaboração", "Entrega", "Domínio técnico" — com um peso.
/// O peso pondera a nota final: nem toda competência importa igual, e um número
/// único que ignora isso engana. Vive dentro do ciclo, não é catálogo global:
/// cada campanha escolhe o que faz sentido medir naquele momento.
model CompetenciaCiclo {
  codComp    BigInt   @id @default(autoincrement()) @map("CODCOMP")
  codTen     BigInt   @map("CODTEN")
  codCiclo   BigInt   @map("CODCICLO")
  nome       String   @map("NOME")
  descricao  String?  @map("DESCRICAO") @db.Text
  /// Peso relativo na média ponderada. Default 1 = todas iguais.
  peso       Int      @default(1) @map("PESO")
  ordem      Int      @default(0) @map("ORDEM")

  tenant Tenant         @relation(fields: [codTen], references: [codTen])
  ciclo  CicloAvaliacao @relation(fields: [codCiclo], references: [codCiclo])
  notas  NotaCompetencia[]

  @@index([codTen, codCiclo])
  @@map("TGPCOMP")
}

/// Avaliação de desempenho de um funcionário dentro de um ciclo (RN-GP-022).
///
/// Uma por funcionário por ciclo (`@@unique`): a mesma pessoa não é avaliada
/// duas vezes na mesma campanha. A `notaFinal` NÃO fica aqui como campo — é
/// derivada das notas por competência (ver `notaFinal`), pelo mesmo motivo do
/// progresso do PDI: um campo à parte poderia contradizer os itens.
model AvaliacaoDesempenho {
  codAval        BigInt    @id @default(autoincrement()) @map("CODAVAL")
  codTen         BigInt    @map("CODTEN")
  codCiclo       BigInt    @map("CODCICLO")
  codFun         BigInt    @map("CODFUN")
  /// Quem avalia — FK p/ TSIUSU, o gestor. Nulo até ser atribuído.
  codUsuAvaliador BigInt?  @map("CODUSUAVALIADOR")
  /// PENDENTE | EM_ANDAMENTO | CONCLUIDA
  status         String    @default("PENDENTE") @map("STATUS")
  comentarioGeral String?  @map("COMENTARIOGERAL") @db.Text
  dhConclusao    DateTime? @map("DHCONCLUSAO")
  dhInc          DateTime  @default(now()) @map("DHINC")
  codUsuInc      BigInt?   @map("CODUSUINC")
  dhAlt          DateTime  @updatedAt @map("DHALT")

  tenant      Tenant         @relation(fields: [codTen], references: [codTen])
  ciclo       CicloAvaliacao @relation(fields: [codCiclo], references: [codCiclo])
  funcionario Funcionario    @relation(fields: [codFun], references: [codFun])
  avaliador   Usuario?       @relation("AvaliadorDesempenho", fields: [codUsuAvaliador], references: [codUsu])
  notas       NotaCompetencia[]

  @@unique([codCiclo, codFun])
  @@index([codTen, codCiclo])
  @@map("TGPAVAL")
}

/// Nota de uma competência dentro de uma avaliação (RN-GP-022).
///
/// Uma por (avaliação, competência) — `@@unique`. A nota é 1..5; o comentário
/// justifica. Concluir a avaliação exige todas as competências do ciclo com
/// nota (ver `podeConcluir`): nota final que ignora critério combinado é fraude
/// involuntária.
model NotaCompetencia {
  codNota    BigInt  @id @default(autoincrement()) @map("CODNOTA")
  codTen     BigInt  @map("CODTEN")
  codAval    BigInt  @map("CODAVAL")
  codComp    BigInt  @map("CODCOMP")
  /// 1 a 5.
  nota       Int     @map("NOTA")
  comentario String? @map("COMENTARIO") @db.Text
  dhAlt      DateTime @updatedAt @map("DHALT")

  tenant      Tenant              @relation(fields: [codTen], references: [codTen])
  avaliacao   AvaliacaoDesempenho @relation(fields: [codAval], references: [codAval])
  competencia CompetenciaCiclo    @relation(fields: [codComp], references: [codComp])

  @@unique([codAval, codComp])
  @@index([codTen, codAval])
  @@map("TGPNOTA")
}

/// Próxima ação do gestor no Painel 360 (performance-360, RN-GP-024).
///
/// O que fazer a seguir com o colaborador — agendar feedback, revisar meta,
/// atribuir treinamento. Uma **recomendação vira tarefa**: nasce de sugestões
/// (aderência, avaliação, IA) ou à mão, e aqui vira algo com prioridade, prazo e
/// responsável. Não é decisão automática — é apoio, e cada uma se descarta.
model ProximaAcao {
  codProx      BigInt    @id @default(autoincrement()) @map("CODPROX")
  codTen       BigInt    @map("CODTEN")
  codFun       BigInt    @map("CODFUN")
  acao         String    @map("ACAO")
  /// ALTA | MEDIA | BAIXA
  prioridade   String    @default("MEDIA") @map("PRIORIDADE")
  prazo        DateTime? @map("PRAZO") @db.Date
  /// Quem deve executar — FK p/ TSIUSU. Nulo = ainda não atribuído.
  codUsuResp   BigInt?   @map("CODUSURESP")
  /// MANUAL | ADERENCIA | AVALIACAO | IA — de onde a sugestão veio.
  origem       String    @default("MANUAL") @map("ORIGEM")
  justificativa String?  @map("JUSTIFICATIVA") @db.Text
  /// ABERTA | CONCLUIDA | DESCARTADA. Descartar é legítimo — sugestão não é ordem.
  status       String    @default("ABERTA") @map("STATUS")
  dhConclusao  DateTime? @map("DHCONCLUSAO")
  dhInc        DateTime  @default(now()) @map("DHINC")
  codUsuInc    BigInt?   @map("CODUSUINC")
  dhAlt        DateTime  @updatedAt @map("DHALT")

  tenant      Tenant      @relation(fields: [codTen], references: [codTen])
  funcionario Funcionario @relation(fields: [codFun], references: [codFun])
  responsavel Usuario?    @relation("ProximaAcaoResp", fields: [codUsuResp], references: [codUsu])

  @@index([codTen, codFun, status])
  @@map("TGPPROX")
}

/// Proposta ao candidato (RN-REC-018).
///
/// A etapa "Proposta" existia no pipeline e não fazia nada: o recrutador
/// arrastava o card e o sistema parava de ajudar exatamente onde a contratação
/// acontece. Aqui a proposta tem valor, data de início, envio e **resposta do
/// candidato** — que responde pelo portal, com token próprio.
///
/// Várias por candidatura de propósito: renegociar é normal, e sobrescrever a
/// anterior apagaria o histórico da negociação.
model Proposta {
  codProp       BigInt    @id @default(autoincrement()) @map("CODPROP")
  codTen        BigInt    @map("CODTEN")
  codCdt        BigInt    @map("CODCDT")
  vlrSalario    Decimal   @map("VLRSALARIO") @db.Decimal(15, 2)
  dtInicio      DateTime? @map("DTINICIO") @db.Date
  tipoContrato  String?   @map("TIPOCONTRATO")
  beneficios    String?   @map("BENEFICIOS") @db.Text
  observacoes   String?   @map("OBSERVACOES") @db.Text
  /// RASCUNHO | ENVIADA | ACEITA | RECUSADA | CANCELADA
  status        String    @default("RASCUNHO") @map("STATUS")
  /// Token opaco (ADR-0004 §5) — o candidato responde sem login.
  tokenPub      String?   @unique @map("TOKENPUB")
  dhEnvio       DateTime? @map("DHENVIO")
  dhResposta    DateTime? @map("DHRESPOSTA")
  /// O que o candidato escreveu ao recusar. Vale mais que o número: é o que
  /// diz se a próxima proposta deve mudar de valor, de data ou de vaga.
  motivoRecusa  String?   @map("MOTIVORECUSA") @db.Text
  dhInc         DateTime  @default(now()) @map("DHINC")
  codUsuInc     BigInt?   @map("CODUSUINC")
  dhAlt         DateTime  @updatedAt @map("DHALT")
  codUsuAlt     BigInt?   @map("CODUSUALT")

  tenant      Tenant      @relation(fields: [codTen], references: [codTen])
  candidatura Candidatura @relation(fields: [codCdt], references: [codCdt])

  @@index([codTen, codCdt])
  @@map("TREPROP")
}

/// Etiqueta do banco de talentos (RN-REC-017).
///
/// Presa ao **candidato**, não à candidatura: "fala inglês" ou "já foi
/// entrevistado aqui" continua valendo quando a pessoa se inscreve em outra
/// vaga. Presa à candidatura, a informação se perderia a cada nova inscrição.
model Tag {
  codTag    BigInt   @id @default(autoincrement()) @map("CODTAG")
  codTen    BigInt   @map("CODTEN")
  nome      String   @map("NOME")
  /// Cor em hex — em volume, a leitura é visual antes de ser textual.
  cor       String   @default("#8A5B3F") @map("COR")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")

  tenant     Tenant         @relation(fields: [codTen], references: [codTen])
  candidatos CandidatoTag[]

  @@unique([codTen, nome])
  @@map("TRETAG")
}

/// Etiqueta aplicada a um candidato (RN-REC-017).
model CandidatoTag {
  codCandTag BigInt   @id @default(autoincrement()) @map("CODCANDTAG")
  codTen     BigInt   @map("CODTEN")
  codCand    BigInt   @map("CODCAND")
  codTag     BigInt   @map("CODTAG")
  dhInc      DateTime @default(now()) @map("DHINC")
  codUsuInc  BigInt?  @map("CODUSUINC")
  /// Soft-delete: o papel da aplicação não tem DELETE em tabela nenhuma
  /// (convenção da plataforma, migration core_v1) — e o histórico de quem
  /// marcou o quê tem valor.
  ativo      String   @default("S") @map("ATIVO") @db.Char(1)

  tenant    Tenant    @relation(fields: [codTen], references: [codTen])
  candidato Candidato @relation(fields: [codCand], references: [codCand])
  tag       Tag       @relation(fields: [codTag], references: [codTag])

  @@unique([codCand, codTag])
  @@index([codTen, codTag])
  @@map("TRECANDTAG")
}

/// Candidatura favoritada (RN-REC-017).
///
/// **Por usuário**, não por candidatura: o favorito de um recrutador não é o do
/// outro. É a diferença entre uma marca pessoal de trabalho e um atributo do
/// candidato — tratar as duas como a mesma coisa faria dois recrutadores
/// disputarem a mesma lista.
model CandidaturaFavorita {
  codFav BigInt   @id @default(autoincrement()) @map("CODFAV")
  codTen BigInt   @map("CODTEN")
  codCdt BigInt   @map("CODCDT")
  codUsu BigInt   @map("CODUSU")
  dhInc  DateTime @default(now()) @map("DHINC")
  /// Soft-delete: desfavoritar apaga a marca, não a linha (sem DELETE).
  ativo  String   @default("S") @map("ATIVO") @db.Char(1)

  tenant      Tenant      @relation(fields: [codTen], references: [codTen])
  candidatura Candidatura @relation(fields: [codCdt], references: [codCdt])
  usuario     Usuario     @relation(fields: [codUsu], references: [codUsu])

  @@unique([codCdt, codUsu])
  @@index([codTen, codUsu])
  @@map("TRECDTFAV")
}

/// Filtro salvo da lista de candidaturas (RN-REC-017).
///
/// Por usuário, pelo mesmo motivo do favorito: o recorte que um recrutador usa
/// todo dia não é o do colega.
model FiltroSalvo {
  codFiltro   BigInt   @id @default(autoincrement()) @map("CODFILTRO")
  codTen      BigInt   @map("CODTEN")
  codUsu      BigInt   @map("CODUSU")
  nome        String   @map("NOME")
  /// Os parâmetros da lista, no mesmo formato da query string.
  filtrosJson Json     @map("FILTROSJSON")
  dhInc       DateTime @default(now()) @map("DHINC")
  /// Soft-delete, mesma razão das demais.
  ativo       String   @default("S") @map("ATIVO") @db.Char(1)

  tenant  Tenant  @relation(fields: [codTen], references: [codTen])
  usuario Usuario @relation(fields: [codUsu], references: [codUsu])

  @@unique([codTen, codUsu, nome])
  @@map("TREFILTRO")
}

/// Formação do candidato (RN-REC-016).
///
/// Tabela própria, e não campo no candidato, porque formação é 1:N: quem tem
/// técnico e superior tem duas, e achatar isso em texto foi justamente o que
/// impedia filtrar por "superior completo".
model FormacaoCandidato {
  codFor       BigInt   @id @default(autoincrement()) @map("CODFOR")
  codTen       BigInt   @map("CODTEN")
  codCand      BigInt   @map("CODCAND")
  /// FUNDAMENTAL | MEDIO | TECNICO | SUPERIOR | POS | MESTRADO | DOUTORADO
  nivel        String   @map("NIVEL")
  curso        String?  @map("CURSO")
  instituicao  String?  @map("INSTITUICAO")
  /// CONCLUIDO | CURSANDO | TRANCADO — cursando não é concluído, e tratar os
  /// dois como iguais faria a triagem aprovar quem ainda não se formou.
  situacao     String   @default("CONCLUIDO") @map("SITUACAO")
  anoConclusao Int?     @map("ANOCONCLUSAO")
  dhInc        DateTime @default(now()) @map("DHINC")

  tenant    Tenant    @relation(fields: [codTen], references: [codTen])
  candidato Candidato @relation(fields: [codCand], references: [codCand])

  @@index([codTen, codCand])
  @@map("TRECANDFOR")
}

/// Horário de entrevista aberto pelo recrutador (RN-REC-015).
///
/// O recrutador abre a grade; o candidato escolhe pelo portal. É o desenho do
/// `InterviewSlot` do SelX 1.0, e existe para eliminar a negociação por e-mail
/// ("pode terça às 14h?") que consome o tempo do recrutador.
model EntrevistaHorario {
  codHor      BigInt   @id @default(autoincrement()) @map("CODHOR")
  codTen      BigInt   @map("CODTEN")
  codVag      BigInt   @map("CODVAG")
  dhInicio    DateTime @map("DHINICIO")
  duracaoMin  Int      @default(45) @map("DURACAOMIN")
  tipo        String   @default("VIDEO") @map("TIPO")
  local       String?  @map("LOCAL")
  linkReuniao String?  @map("LINKREUNIAO") @db.Text
  /// Quem conduz. Nulo = ainda não definido; a entrevista herda no agendamento.
  codUsuEntrev BigInt? @map("CODUSUENTREV")
  /// LIVRE | RESERVADO | CANCELADO.
  status      String   @default("LIVRE") @map("STATUS")
  dhInc       DateTime @default(now()) @map("DHINC")
  codUsuInc   BigInt?  @map("CODUSUINC")

  tenant      Tenant       @relation(fields: [codTen], references: [codTen])
  vaga        Vaga         @relation(fields: [codVag], references: [codVag])
  entrevistas Entrevista[]

  @@index([codTen, codVag, dhInicio])
  @@map("TREENTREVHOR")
}

/// Entrevista agendada (RN-REC-015).
///
/// Até aqui o pipeline tinha uma etapa "Entrevista" que não levava a lugar
/// nenhum: a aba da vaga era só a lista de quem estava naquele estágio. Não
/// havia horário, entrevistador, link nem confirmação.
///
/// Mover a candidatura para "interview" **não** cria entrevista sozinho — quem
/// decide quando e com quem é o recrutador, e adivinhar isso encheria a agenda
/// de compromissos que ninguém marcou.
model Entrevista {
  codEntrev    BigInt    @id @default(autoincrement()) @map("CODENTREV")
  codTen       BigInt    @map("CODTEN")
  codCdt       BigInt    @map("CODCDT")
  /// Preenchido quando o candidato escolheu um horário da grade.
  codHor       BigInt?   @map("CODHOR")
  dhInicio     DateTime  @map("DHINICIO")
  duracaoMin   Int       @default(45) @map("DURACAOMIN")
  tipo         String    @default("VIDEO") @map("TIPO")
  local        String?   @map("LOCAL")
  linkReuniao  String?   @map("LINKREUNIAO") @db.Text
  codUsuEntrev BigInt?   @map("CODUSUENTREV")
  /// AGENDADA | REALIZADA | CANCELADA | NAO_COMPARECEU.
  status       String    @default("AGENDADA") @map("STATUS")
  /// Parecer do entrevistador — interno, nunca sai no portal do candidato.
  parecer      String?   @map("PARECER") @db.Text
  dhInc        DateTime  @default(now()) @map("DHINC")
  codUsuInc    BigInt?   @map("CODUSUINC")
  dhAlt        DateTime  @updatedAt @map("DHALT")
  codUsuAlt    BigInt?   @map("CODUSUALT")

  tenant      Tenant             @relation(fields: [codTen], references: [codTen])
  candidatura Candidatura        @relation(fields: [codCdt], references: [codCdt])
  horario     EntrevistaHorario? @relation(fields: [codHor], references: [codHor])
  entrevistador Usuario?         @relation("EntrevistaEntrevistador", fields: [codUsuEntrev], references: [codUsu])

  @@index([codTen, codCdt])
  @@index([codTen, dhInicio])
  @@map("TREENTREV")
}

/// Fila de e-mails (RN-SX-001).
///
/// **Fila, não envio direto.** Mandar o e-mail dentro da requisição amarraria a
/// ação do recrutador à saúde do SMTP: servidor fora do ar viraria "não foi
/// possível convidar o candidato", quando o convite na verdade foi criado. Aqui
/// a ação grava a intenção e responde; a entrega é assíncrona e retentável.
///
/// Porte do `EmailOutbox` do SelX 1.0, que já usava esse desenho.
model EmailFila {
  codEmail     BigInt    @id @default(autoincrement()) @map("CODEMAIL")
  codTen       BigInt    @map("CODTEN")
  destinatario String    @map("DESTINATARIO")
  assunto      String    @map("ASSUNTO")
  corpoTexto   String    @map("CORPOTEXTO") @db.Text
  corpoHtml    String?   @map("CORPOHTML") @db.Text
  template     String    @map("TEMPLATE")
  /// Chave de idempotência: impede que a mesma mensagem saia duas vezes quando
  /// o recrutador clica de novo ou a fila é reprocessada. E-mail repetido para
  /// candidato é dano de reputação, não incômodo.
  chaveIdem    String    @unique @map("CHAVEIDEM")
  status       String    @default("PENDENTE") @map("STATUS")
  tentativas   Int       @default(0) @map("TENTATIVAS")
  erro         String?   @map("ERRO") @db.Text
  dhEnvio      DateTime? @map("DHENVIO")
  dhInc        DateTime  @default(now()) @map("DHINC")
  codUsuInc    BigInt?   @map("CODUSUINC")

  tenant Tenant @relation(fields: [codTen], references: [codTen])

  @@index([status, dhInc])
  @@index([codTen, dhInc])
  @@map("TSXEMAIL")
}

/// Configuração de IA por tenant.
///
/// Tabela própria em vez de coluna em `TSXTEN`: o papel `selx_app` tem INSERT e
/// UPDATE **revogados** na tabela de tenants de propósito (migration `core_v1`:
/// "lê, mas não altera tenants/permissões"). Configuração que a empresa edita
/// pela interface precisa morar onde a aplicação escreve.
model ConfiguracaoIa {
  codIaCfg   BigInt   @id @default(autoincrement()) @map("CODIACFG")
  codTen     BigInt   @unique @map("CODTEN")
  /// "nuvem" (padrão) ou "local". Preferência, não política: dado marcado como
  /// sensível vai para o provedor local de qualquer forma (ADR-0003).
  provedorIa String   @default("nuvem") @map("PROVEDORIA")
  dhInc      DateTime @default(now()) @map("DHINC")
  codUsuInc  BigInt?  @map("CODUSUINC")
  dhAlt      DateTime @updatedAt @map("DHALT")
  codUsuAlt  BigInt?  @map("CODUSUALT")

  tenant Tenant @relation(fields: [codTen], references: [codTen])

  @@map("TSXIACFG")
}

/// Análise de candidato por IA (RN-REC-013) — explica o match já calculado,
/// nunca o produz. Cacheada por candidatura: é chamada paga e o recrutador
/// reabre o painel muitas vezes.
model IAAnaliseCandidatura {
  codIaAnalise BigInt   @id @default(autoincrement()) @map("CODIAANALISE")
  codTen       BigInt   @map("CODTEN")
  codCdt       BigInt   @map("CODCDT")
  conteudoJson Json     @map("CONTEUDOJSON")
  /// Hash do dossiê enviado. Currículo novo ou avaliação comportamental
  /// concluída mudam o hash e revelam que a análise guardada envelheceu —
  /// mesma ideia do `HASHENTRADA` do match determinístico.
  hashEntrada  String   @map("HASHENTRADA")
  provedor     String?  @map("PROVEDOR")
  modeloUsado  String?  @map("MODELOUSADO")
  versaoPrompt String?  @map("VERSAOPROMPT")
  duracaoMs    Int?     @map("DURACAOMS")
  status       String   @default("OK") @map("STATUS")
  dhInc        DateTime @default(now()) @map("DHINC")
  codUsuInc    BigInt?  @map("CODUSUINC")

  tenant      Tenant      @relation(fields: [codTen], references: [codTen])
  candidatura Candidatura @relation(fields: [codCdt], references: [codCdt])

  @@index([codTen, codCdt])
  @@map("TREIAANALISE")
}

/// Resumo de match determinístico (1:1 com a candidatura) — nunca LLM no score.
model MatchResumo {
  codMatch         BigInt   @id @default(autoincrement()) @map("CODMATCH")
  codTen           BigInt   @map("CODTEN")
  codCdt           BigInt   @unique @map("CODCDT")
  versaoMatch      String   @map("VERSAOMATCH")
  scoreGeral       Int      @map("SCOREGERAL")
  scoreContratacao Int?     @map("SCORECONTRATACAO")
  scoreCultura     Int?     @map("SCORECULTURA")
  driverPrincipal  String?  @map("DRIVERPRINCIPAL")
  qtdGapsCrit      Int      @default(0) @map("QTDGAPSCRIT")
  qtdGapsMelh      Int      @default(0) @map("QTDGAPSMELH")
  hashEntrada      String   @map("HASHENTRADA")
  dhCalc           DateTime @default(now()) @map("DHCALC")

  tenant      Tenant      @relation(fields: [codTen], references: [codTen])
  candidatura Candidatura @relation(fields: [codCdt], references: [codCdt])

  @@map("TREMATCH")
}

// ===== Gestão de Pessoas — Avaliação Comportamental (TGP, exclusivo do SelexOps) =====
// Metodologia própria (Direcionamento/Conexão/Sustentação/Precisão — nunca expor
// equivalência com metodologias comerciais). Motor de pontuação determinístico
// (RN-GP-006); IA só explica resultado já calculado, nunca decide. Ver
// "09 - Módulos/Gestão de Pessoas/01 - Modelo de Dados.md". Catálogo (fator,
// pergunta, escala, modelo) é GLOBAL — metodologia própria, não customizada por
// tenant nesta fase (mesma exceção de TSXPERM). Todo o resto é por tenant + RLS.

/// Fator/dimensão comportamental (DIR/CON/SUS/PRE hoje; genérica p/ dimensões
/// complementares futuras — RN-GP-002). GLOBAL.
model FatorComportamental {
  codFat    BigInt   @id @default(autoincrement()) @map("CODFAT")
  sigla     String   @unique @map("SIGLA")
  nome      String   @map("NOME")
  descricao String?  @map("DESCRICAO")
  ordem     Int      @default(1) @map("ORDEM")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  perguntas          PerguntaComportamental[]
  perfilVagaFatores  PerfilComportamentalVagaFator[]
  perfilPadraoFatores PerfilComportamentalPadraoFator[]
  resultadoFatores   ResultadoComportamentalFator[]
  aderenciaFatores   AderenciaComportamentalVagaFator[]

  @@map("TGPFAT")
}

/// Banco de perguntas (RN-GP-001). GLOBAL — ver "02 - Banco de Perguntas.md".
model PerguntaComportamental {
  codPer     BigInt   @id @default(autoincrement()) @map("CODPER")
  codFat     BigInt   @map("CODFAT")
  texto      String   @map("TEXTO")
  tipo       String   @map("TIPO")
  peso       Decimal  @default(1.0) @map("PESO") @db.Decimal(3, 2)
  status     String   @default("ATIVA") @map("STATUS")
  versao     Int      @default(1) @map("VERSAO")
  dificuldadeInterpretacao String? @map("DIFICULDADEINTERPRETACAO")
  categoria  String?  @map("CATEGORIA")
  idioma     String   @default("pt-BR") @map("IDIOMA")
  tagsJson   Json?    @map("TAGSJSON")
  justificativaMetodologica String? @map("JUSTIFICATIVAMETODOLOGICA")
  dhInc      DateTime @default(now()) @map("DHINC")

  fator    FatorComportamental @relation(fields: [codFat], references: [codFat])
  modelos  ModeloAvaliacaoPergunta[]
  respostas RespostaComportamental[]

  @@index([codFat])
  @@map("TGPPER")
}

/// Opção da escala de resposta (normativa 1-5 no v1). GLOBAL.
model EscalaResposta {
  codEsc      BigInt @id @default(autoincrement()) @map("CODESC")
  tipoEscala  String @default("NORMATIVA_1_5") @map("TIPOESCALA")
  valor       Int    @map("VALOR")
  rotulo      String @map("ROTULO")
  ordem       Int    @map("ORDEM")

  respostas RespostaComportamental[]

  @@map("TGPESC")
}

/// Modelo/questionário de avaliação (ex.: "Avaliação Comportamental Padrão v1"). GLOBAL.
model ModeloAvaliacaoComportamental {
  codMod   BigInt    @id @default(autoincrement()) @map("CODMOD")
  /// NULL = catálogo da plataforma (seed, vale para todos); preenchido = questionário
  /// próprio do tenant. Sem isso, um tenant publicando um modelo virava o padrão
  /// de TODOS os outros — a tabela é global e o padrão é "publicado de maior versão".
  codTen   BigInt?   @map("CODTEN")
  nome     String    @map("NOME")
  versao   Int       @default(1) @map("VERSAO")
  status   String    @default("RASCUNHO") @map("STATUS")
  tempoEstimadoMin Int? @map("TEMPOESTIMADOMIN")
  tempoEstimadoMax Int? @map("TEMPOESTIMADOMAX")
  dhPublicacao DateTime? @map("DHPUBLICACAO")
  dhInc    DateTime  @default(now()) @map("DHINC")

  perguntas ModeloAvaliacaoPergunta[]
  perfisVaga PerfilComportamentalVaga[]
  convites  ConviteComportamental[]

  @@map("TGPMOD")
}

/// Modelo × Pergunta (N:N, com ordem de cadastro). GLOBAL.
model ModeloAvaliacaoPergunta {
  codModPer BigInt @id @default(autoincrement()) @map("CODMODPER")
  codMod    BigInt @map("CODMOD")
  codPer    BigInt @map("CODPER")
  ordem     Int    @default(1) @map("ORDEM")

  modelo   ModeloAvaliacaoComportamental @relation(fields: [codMod], references: [codMod])
  pergunta PerguntaComportamental        @relation(fields: [codPer], references: [codPer])

  @@unique([codMod, codPer])
  @@map("TGPMODPER")
}

/// Perfil comportamental desejado da vaga (RN-GP-008). FK cross-módulo p/ TREVAG
/// (Recrutamento), mesmo padrão de TREVAG.CODCAR -> TFPCAR do Core.
model PerfilComportamentalVaga {
  codPerVag BigInt   @id @default(autoincrement()) @map("CODPERVAG")
  codTen    BigInt   @map("CODTEN")
  codVag    BigInt   @map("CODVAG")
  codMod    BigInt   @map("CODMOD")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")

  tenant   Tenant                        @relation(fields: [codTen], references: [codTen])
  vaga     Vaga                          @relation(fields: [codVag], references: [codVag])
  modelo   ModeloAvaliacaoComportamental @relation(fields: [codMod], references: [codMod])
  fatores  PerfilComportamentalVagaFator[]
  aderencias AderenciaComportamentalVaga[]

  @@index([codTen, codVag])
  @@map("TGPPERVAG")
}

/// Perfil da vaga × fator: faixa desejada, peso, importância, eliminatório (RN-GP-009).
model PerfilComportamentalVagaFator {
  codPerVagFat BigInt  @id @default(autoincrement()) @map("CODPERVAGFAT")
  codTen       BigInt  @map("CODTEN")
  codPerVag    BigInt  @map("CODPERVAG")
  codFat       BigInt  @map("CODFAT")
  minimo       Int     @map("MINIMO")
  maximo       Int     @map("MAXIMO")
  peso         Decimal @default(1.0) @map("PESO") @db.Decimal(3, 2)
  importancia  String  @default("MEDIA") @map("IMPORTANCIA")
  eliminatorio String  @default("N") @map("ELIMINATORIO") @db.Char(1)
  justificativa String? @map("JUSTIFICATIVA")
  tolerancia   Int?    @map("TOLERANCIA")

  tenant     Tenant                    @relation(fields: [codTen], references: [codTen])
  perfilVaga PerfilComportamentalVaga  @relation(fields: [codPerVag], references: [codPerVag])
  fator      FatorComportamental       @relation(fields: [codFat], references: [codFat])

  @@unique([codPerVag, codFat])
  @@map("TGPPERVAGFAT")
}

/// Perfil comportamental padrão do tenant — fallback quando a vaga não tem
/// perfil próprio configurado (RN-GP-008, extensão 2026-07-21). Só a faixa por
/// fator: a escolha de MODELO (questionário) já tem seu próprio fallback (o
/// modelo padrão publicado), resolvido em avaliacao-comportamental.controller.ts.
model PerfilComportamentalPadrao {
  codPerPad BigInt   @id @default(autoincrement()) @map("CODPERPAD")
  codTen    BigInt   @map("CODTEN")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")

  tenant  Tenant                             @relation(fields: [codTen], references: [codTen])
  fatores PerfilComportamentalPadraoFator[]

  @@index([codTen])
  @@map("TGPPERPAD")
}

/// Perfil padrão × fator: mesma forma de TGPPERVAGFAT, sem vínculo de vaga.
model PerfilComportamentalPadraoFator {
  codPerPadFat BigInt  @id @default(autoincrement()) @map("CODPERPADFAT")
  codTen       BigInt  @map("CODTEN")
  codPerPad    BigInt  @map("CODPERPAD")
  codFat       BigInt  @map("CODFAT")
  minimo       Int     @map("MINIMO")
  maximo       Int     @map("MAXIMO")
  peso         Decimal @default(1.0) @map("PESO") @db.Decimal(3, 2)
  importancia  String  @default("MEDIA") @map("IMPORTANCIA")
  eliminatorio String  @default("N") @map("ELIMINATORIO") @db.Char(1)
  justificativa String? @map("JUSTIFICATIVA")
  tolerancia   Int?    @map("TOLERANCIA")

  tenant     Tenant                      @relation(fields: [codTen], references: [codTen])
  perfilPad  PerfilComportamentalPadrao  @relation(fields: [codPerPad], references: [codPerPad])
  fator      FatorComportamental         @relation(fields: [codFat], references: [codFat])

  @@unique([codPerPad, codFat])
  @@map("TGPPERPADFAT")
}

/// Convite (token opaco público — ADR-0004 §5, mesmo padrão de Admissão Digital).
/// FK cross-módulo p/ TRECDT (Recrutamento).
model ConviteComportamental {
  codConv      BigInt    @id @default(autoincrement()) @map("CODCONV")
  codTen       BigInt    @map("CODTEN")
  codCdt       BigInt    @map("CODCDT")
  codMod       BigInt    @map("CODMOD")
  tokenPub     String    @unique @map("TOKENPUB")
  status       String    @default("PENDENTE") @map("STATUS")
  dhEnvio      DateTime  @default(now()) @map("DHENVIO")
  dhExpiracao  DateTime? @map("DHEXPIRACAO")
  codUsuInc    BigInt?   @map("CODUSUINC")

  tenant      Tenant                        @relation(fields: [codTen], references: [codTen])
  candidatura Candidatura                   @relation(fields: [codCdt], references: [codCdt])
  modelo      ModeloAvaliacaoComportamental @relation(fields: [codMod], references: [codMod])
  sessao      SessaoComportamental?

  @@index([codTen, codCdt])
  @@map("TGPCONV")
}

/// Sessão de resposta (1:1 com convite) — sustenta pausa/retomada (RN-GP-004).
model SessaoComportamental {
  codSes             BigInt    @id @default(autoincrement()) @map("CODSES")
  codTen             BigInt    @map("CODTEN")
  codConv            BigInt    @unique @map("CODCONV")
  dhInicio           DateTime  @default(now()) @map("DHINICIO")
  codUltimaPergunta  BigInt?   @map("CODULTIMAPERGUNTA")
  dhConclusao        DateTime? @map("DHCONCLUSAO")
  tempoTotalSeg      Int?      @map("TEMPOTOTALSEG")

  tenant       Tenant                       @relation(fields: [codTen], references: [codTen])
  convite      ConviteComportamental        @relation(fields: [codConv], references: [codConv])
  respostas    RespostaComportamental[]
  consentimento ConsentimentoComportamental?
  resultado    ResultadoComportamental?

  @@map("TGPSES")
}

/// Termo de ciência aceito antes de responder.
model ConsentimentoComportamental {
  codConsent BigInt   @id @default(autoincrement()) @map("CODCONSENT")
  codTen     BigInt   @map("CODTEN")
  codSes     BigInt   @unique @map("CODSES")
  dhAceite   DateTime @default(now()) @map("DHACEITE")
  ip         String?  @map("IP")

  tenant  Tenant                @relation(fields: [codTen], references: [codTen])
  sessao  SessaoComportamental  @relation(fields: [codSes], references: [codSes])

  @@map("TGPCONSENT")
}

/// Resposta individual a uma pergunta (RN-GP-005: respostas originais nunca descartadas).
model RespostaComportamental {
  codResp    BigInt   @id @default(autoincrement()) @map("CODRESP")
  codTen     BigInt   @map("CODTEN")
  codSes     BigInt   @map("CODSES")
  codPer     BigInt   @map("CODPER")
  codEsc     BigInt   @map("CODESC")
  dhResposta DateTime @default(now()) @map("DHRESPOSTA")

  tenant   Tenant                  @relation(fields: [codTen], references: [codTen])
  sessao   SessaoComportamental    @relation(fields: [codSes], references: [codSes])
  pergunta PerguntaComportamental  @relation(fields: [codPer], references: [codPer])
  escala   EscalaResposta          @relation(fields: [codEsc], references: [codEsc])

  @@unique([codSes, codPer])
  @@index([codTen, codSes])
  @@map("TGPRESP")
}

/// Resultado consolidado (1:1 com sessão concluída). Nunca recalculado
/// silenciosamente após mudança de regra (RN-GP-007).
model ResultadoComportamental {
  codResult             BigInt   @id @default(autoincrement()) @map("CODRESULT")
  codTen                BigInt   @map("CODTEN")
  codSes                BigInt   @unique @map("CODSES")
  versaoAlgoritmo       String   @map("VERSAOALGORITMO")
  versaoMod             Int      @map("VERSAOMOD")
  indicadorConsistencia String   @map("INDICADORCONSISTENCIA")
  percRespNeutras       Decimal  @map("PERCRESPNEUTRAS") @db.Decimal(5, 2)
  percRespUniformes     Decimal  @map("PERCRESPUNIFORMES") @db.Decimal(5, 2)
  tempoTotalSeg         Int?     @map("TEMPOTOTALSEG")
  dhCalc                DateTime @default(now()) @map("DHCALC")

  tenant     Tenant                          @relation(fields: [codTen], references: [codTen])
  sessao     SessaoComportamental            @relation(fields: [codSes], references: [codSes])
  fatores    ResultadoComportamentalFator[]
  aderencias AderenciaComportamentalVaga[]

  @@map("TGPRESULT")
}

/// Resultado × fator: bruto, mín/máx possível, percentual, média, desvio, faixa.
model ResultadoComportamentalFator {
  codResultFat          BigInt  @id @default(autoincrement()) @map("CODRESULTFAT")
  codTen                BigInt  @map("CODTEN")
  codResult             BigInt  @map("CODRESULT")
  codFat                BigInt  @map("CODFAT")
  pontuacaoBruta        Decimal @map("PONTUACAOBRUTA") @db.Decimal(8, 2)
  minimoPossivel        Decimal @map("MINIMOPOSSIVEL") @db.Decimal(8, 2)
  maximoPossivel        Decimal @map("MAXIMOPOSSIVEL") @db.Decimal(8, 2)
  percentualNormalizado Decimal @map("PERCENTUALNORMALIZADO") @db.Decimal(5, 2)
  media                 Decimal @map("MEDIA") @db.Decimal(5, 2)
  desvio                Decimal @map("DESVIO") @db.Decimal(5, 2)
  faixaInterpretativa   String  @map("FAIXAINTERPRETATIVA")

  tenant    Tenant                  @relation(fields: [codTen], references: [codTen])
  resultado ResultadoComportamental @relation(fields: [codResult], references: [codResult])
  fator     FatorComportamental     @relation(fields: [codFat], references: [codFat])

  @@unique([codResult, codFat])
  @@map("TGPRESULTFAT")
}

/// Aderência à vaga (RN-GP-009 — nunca é probabilidade de sucesso profissional).
model AderenciaComportamentalVaga {
  codAderVag BigInt   @id @default(autoincrement()) @map("CODADERVAG")
  codTen     BigInt   @map("CODTEN")
  codResult  BigInt   @map("CODRESULT")
  codPerVag  BigInt   @map("CODPERVAG")
  aderenciaGeral Decimal @map("ADERENCIAGERAL") @db.Decimal(5, 2)
  versao     String   @map("VERSAO")
  dhCalc     DateTime @default(now()) @map("DHCALC")

  tenant     Tenant                        @relation(fields: [codTen], references: [codTen])
  resultado  ResultadoComportamental       @relation(fields: [codResult], references: [codResult])
  perfilVaga PerfilComportamentalVaga      @relation(fields: [codPerVag], references: [codPerVag])
  fatores    AderenciaComportamentalVagaFator[]

  @@unique([codResult, codPerVag])
  @@map("TGPADERVAG")
}

/// Aderência × fator: distância da faixa, aderência da dimensão, dentro/fora.
model AderenciaComportamentalVagaFator {
  codAderVagFat BigInt  @id @default(autoincrement()) @map("CODADERVAGFAT")
  codTen        BigInt  @map("CODTEN")
  codAderVag    BigInt  @map("CODADERVAG")
  codFat        BigInt  @map("CODFAT")
  distanciaFaixa     Decimal @map("DISTANCIAFAIXA") @db.Decimal(5, 2)
  aderenciaDimensao  Decimal @map("ADERENCIADIMENSAO") @db.Decimal(5, 2)
  dentroDaFaixa      String  @map("DENTRODAFAIXA") @db.Char(1)

  tenant        Tenant                       @relation(fields: [codTen], references: [codTen])
  aderenciaVaga AderenciaComportamentalVaga  @relation(fields: [codAderVag], references: [codAderVag])
  fator         FatorComportamental          @relation(fields: [codFat], references: [codFat])

  @@unique([codAderVag, codFat])
  @@map("TGPADERVAGFAT")
}

// ===== Assinatura eletrônica de documentos (Core — TSX, exclusivo do SelexOps) =====
// v1 sem fornecedor externo (decisão do Thadeu, 2026-07-14): assinatura simples
// (consentimento + hash do conteúdo + IP + timestamp), suficiente para a maioria
// dos documentos de admissão. Token opaco para acesso público (ADR-0004 §5) —
// funcionário assina sem precisar de login/portal (que ainda não existe).

/// Modelo de documento por tenant, com placeholders {{campo}} substituídos no envio.
model DocumentoModelo {
  codDoc         BigInt   @id @default(autoincrement()) @map("CODDOC")
  codTen         BigInt   @map("CODTEN")
  nomeDoc        String   @map("NOMEDOC")
  conteudoModelo String   @map("CONTEUDOMODELO") @db.Text
  dhInc          DateTime @default(now()) @map("DHINC")
  codUsuInc      BigInt?  @map("CODUSUINC")
  dhAlt          DateTime @updatedAt @map("DHALT")
  codUsuAlt      BigInt?  @map("CODUSUALT")
  ativo          String   @default("S") @map("ATIVO") @db.Char(1)

  tenant      Tenant       @relation(fields: [codTen], references: [codTen])
  assinaturas Assinatura[]
  kitItens    KitAdmissionalDocumento[]

  @@map("TSXDOC")
}

/// Envio de um documento a um funcionário para assinatura (envelope).
model Assinatura {
  codAssin            BigInt    @id @default(autoincrement()) @map("CODASSIN")
  codTen              BigInt    @map("CODTEN")
  codDoc              BigInt    @map("CODDOC")
  codFun              BigInt    @map("CODFUN")
  conteudoRenderizado String    @map("CONTEUDORENDERIZADO") @db.Text
  hashConteudo        String    @map("HASHCONTEUDO")
  tokenPub            String    @unique @map("TOKENPUB")
  status              String    @default("PENDENTE") @map("STATUS")
  dhEnvio             DateTime  @default(now()) @map("DHENVIO")
  dhAssinatura        DateTime? @map("DHASSINATURA")
  ipAssinatura        String?   @map("IPASSINATURA")
  codUsuInc           BigInt?   @map("CODUSUINC")

  tenant      Tenant          @relation(fields: [codTen], references: [codTen])
  documento   DocumentoModelo @relation(fields: [codDoc], references: [codDoc])
  funcionario Funcionario     @relation(fields: [codFun], references: [codFun])

  @@index([codTen, codFun])
  @@map("TSXASSIN")
}

// ===== Kit Admissional (Core — TSX) =====

/// Kit nomeado de documentos enviados juntos ao aprovar uma admissão.
model KitAdmissional {
  codKit    BigInt   @id @default(autoincrement()) @map("CODKIT")
  codTen    BigInt   @map("CODTEN")
  nomeKit   String   @map("NOMEKIT")
  dhInc     DateTime @default(now()) @map("DHINC")
  codUsuInc BigInt?  @map("CODUSUINC")
  ativo     String   @default("S") @map("ATIVO") @db.Char(1)

  tenant Tenant                   @relation(fields: [codTen], references: [codTen])
  itens  KitAdmissionalDocumento[]

  @@map("TSXKIT")
}

model KitAdmissionalDocumento {
  codKitDoc BigInt @id @default(autoincrement()) @map("CODKITDOC")
  codTen    BigInt @map("CODTEN")
  codKit    BigInt @map("CODKIT")
  codDoc    BigInt @map("CODDOC")
  ordem     Int    @default(1) @map("ORDEM")

  tenant    Tenant          @relation(fields: [codTen], references: [codTen])
  kit       KitAdmissional  @relation(fields: [codKit], references: [codKit])
  documento DocumentoModelo @relation(fields: [codDoc], references: [codDoc])

  @@unique([codKit, codDoc])
  @@map("TSXKITDOC")
}

// ===== Processo de Admissão (Recrutamento e Seleção — TRE) =====
// Fluxo real informado pelo Thadeu (2026-07-14, observado no vlow): o
// funcionário só é criado depois que o DP aprova dados/documentos do
// candidato — ver "09 - Módulos/Recrutamento e Seleção/04".

model ProcessoAdmissao {
  codAdmProc              BigInt    @id @default(autoincrement()) @map("CODADMPROC")
  codTen                  BigInt    @map("CODTEN")
  codCdt                  BigInt    @unique @map("CODCDT")
  status                  String    @default("AGUARDANDO_CANDIDATO") @map("STATUS")
  tokenPub                String    @unique @map("TOKENPUB")
  dadosComplementaresJson Json?     @map("DADOSCOMPLEMENTARESJSON")
  obsAjuste               String?   @map("OBSAJUSTE")
  dhInicio                DateTime  @default(now()) @map("DHINICIO")
  dhEnvioCandidato        DateTime? @map("DHENVIOCANDIDATO")
  dhAprovacao             DateTime? @map("DHAPROVACAO")
  codUsuAprov             BigInt?   @map("CODUSUAPROV")
  codUsuInc               BigInt?   @map("CODUSUINC")

  tenant      Tenant          @relation(fields: [codTen], references: [codTen])
  candidatura Candidatura     @relation(fields: [codCdt], references: [codCdt])
  anexos      AdmissaoAnexo[]

  @@map("TREADMPROC")
}

model AdmissaoAnexo {
  codAdmAnexo  BigInt   @id @default(autoincrement()) @map("CODADMANEXO")
  codTen       BigInt   @map("CODTEN")
  codAdmProc   BigInt   @map("CODADMPROC")
  categoria    String   @map("CATEGORIA")
  arquivo      String   @map("ARQUIVO")
  nomeOriginal String   @map("NOMEORIGINAL")
  dhInc        DateTime @default(now()) @map("DHINC")

  tenant   Tenant           @relation(fields: [codTen], references: [codTen])
  processo ProcessoAdmissao @relation(fields: [codAdmProc], references: [codAdmProc])

  @@index([codTen, codAdmProc])
  @@map("TREADMANEXO")
}
