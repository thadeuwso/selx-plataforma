      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|subtle|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'subtle' | 'destructive'."
