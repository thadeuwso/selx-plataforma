# Copie para .env e ajuste. NUNCA commite o .env real.

# Banco (docker-compose local)
DATABASE_URL="postgresql://selx:selx_dev@localhost:5433/selx"
DATABASE_URL_APP="postgresql://selx_app:selx_app_dev@localhost:5433/selx" # papel de aplicação (RLS)

# Fila / cache
REDIS_URL="redis://localhost:6379"

# API
API_PORT=3001
JWT_SECRET="troque-em-desenvolvimento"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001"

# AI Gateway (ai-service) — provedores configurados por adapter (ADR-0003)
AI_SERVICE_PORT=8000
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# E-mail (Mailpit local)
SMTP_HOST=localhost
SMTP_PORT=1025
